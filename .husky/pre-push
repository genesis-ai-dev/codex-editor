set -eu

# Allow bypass via env if needed
if [ "${SKIP_PREPUSH_TESTS:-}" = "1" ]; then
  exit 0
fi

# --------------------------------------------------------------------------
# PATH bootstrap
# --------------------------------------------------------------------------
# Some GUI git clients (GitHub Desktop, Tower, Fork, etc.) launch hooks with
# a heavily stripped PATH that omits /usr/local/bin, /opt/homebrew/bin, and
# any NVM-managed node directories. That makes `node`/`npm` unfindable and
# the hook fails with "env: node: No such file or directory" (exit 127).
#
# Add common locations explicitly, then load NVM if present so we resolve to
# the user's default node version.
# --------------------------------------------------------------------------
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Try NVM (default version) when node is still missing.
if ! command -v node >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$NVM_DIR/nvm.sh" >/dev/null 2>&1 || true
  fi
fi

# Fallback: if NVM didn't load but a default-alias version exists, add it to PATH.
if ! command -v node >/dev/null 2>&1 && [ -d "$HOME/.nvm/versions/node" ]; then
  default_alias_file="$HOME/.nvm/alias/default"
  default_version=""
  if [ -f "$default_alias_file" ]; then
    default_version="$(cat "$default_alias_file" 2>/dev/null || true)"
  fi
  if [ -z "$default_version" ]; then
    # Pick the highest-installed version as a last resort.
    default_version="$(ls "$HOME/.nvm/versions/node" 2>/dev/null | sort -V | tail -n1)"
  fi
  if [ -n "$default_version" ] && [ -x "$HOME/.nvm/versions/node/$default_version/bin/node" ]; then
    export PATH="$HOME/.nvm/versions/node/$default_version/bin:$PATH"
  fi
fi

if ! command -v node >/dev/null 2>&1 || ! command -v npm >/dev/null 2>&1; then
  echo "❌ pre-push: cannot find node/npm in PATH." >&2
  echo "   PATH=$PATH" >&2
  echo "   To bypass this hook for one push, re-run with: SKIP_PREPUSH_TESTS=1 git push" >&2
  exit 1
fi

# Stash any local changes (tracked, staged, and untracked) so tests run against HEAD only
pre_stash_ref="$(git rev-parse -q --verify refs/stash || true)"
STASH_CREATED=0
STASH_MSG="pre-push-$(date +%s)-$$"

# Detect a dirty working tree (unstaged, staged, or untracked)
if git diff --quiet --no-ext-diff \
   && git diff --quiet --no-ext-diff --cached \
   && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  : # clean working tree
else
  git stash push -u -m "$STASH_MSG" >/dev/null 2>&1 || true
  post_stash_ref="$(git rev-parse -q --verify refs/stash || true)"
  if [ "${pre_stash_ref:-}" != "${post_stash_ref:-}" ]; then
    STASH_CREATED=1
  fi
fi

restore_stash() {
  if [ "$STASH_CREATED" -eq 1 ]; then
    # Try to restore the exact stash entry we created
    stash_entry="$(git stash list | grep "$STASH_MSG" | head -n1 | cut -d: -f1 || true)"
    if [ -n "$stash_entry" ]; then
      git stash apply "$stash_entry" >/dev/null 2>&1 || true
      git stash drop "$stash_entry" >/dev/null 2>&1 || true
    else
      git stash pop >/dev/null 2>&1 || true
    fi
  fi
}
trap restore_stash EXIT INT TERM

# Run tests in-place against the current repository (HEAD)
echo "🧪 Running main extension tests..."
npm test

echo "🧪 Running webview tests..."
npm run test:webviews
